  "components": {
    "schemas": {
      "DiagnosisRequest": {
        "properties": {
          "exam_id": {
            "type": "string",
            "title": "Exam Id",
            "description": "AI 분석할 검사 기록 UUID (eye_exams.id)"
          },
          "additional_context": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 1000
              },
              {
                "type": "null"
              }
            ],
            "title": "Additional Context",
            "description": "추가 임상 맥락 (혈당 수치, 복약 이력 등 — AI 정확도 향상에 도움)"
          },
          "strategy": {
            "type": "string",
            "pattern": "^(pipeline|consensus|debate|fastest)$",
            "title": "Strategy",
            "description": "Orchestrator 전략:\n- **consensus** (권장): FAST+HEAVY 두 모델 합의 — 의료 안전 최적\n- pipeline: 순차 실행 (Planner→Generator→Reviewer→Fixer)\n- debate: 두 모델 논쟁 후 합의\n- fastest: 가장 빠른 모델 단독 실행 (응급 상황)",
            "default": "consensus",
            "examples": [
              "consensus"
            ]
          }
        },
        "type": "object",
        "required": [
          "exam_id"
        ],
        "title": "DiagnosisRequest",
        "example": {
          "additional_context": "환자 HbA1c 8.2%, 당뇨병 진단 12년차, 인슐린 치료 중",
          "exam_id": "b2c3d4e5-f6a7-8901-bcde-f12345678901",
          "strategy": "consensus"
        }
      },
      "DiagnosisResponse": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id",
            "description": "진단 UUID"
          },
          "exam_id": {
            "type": "string",
            "title": "Exam Id",
            "description": "관련 검사 UUID"
          },
          "diagnosis_code": {
            "type": "string",
            "title": "Diagnosis Code",
            "description": "ICD-10 진단 코드 (예: H36.0)"
          },
          "diagnosis_name": {
            "type": "string",
            "title": "Diagnosis Name",
            "description": "진단명 (한국어)"
          },
          "severity": {
            "type": "string",
            "title": "Severity",
            "description": "중증도: normal | mild | moderate | severe | critical"
          },
          "report": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Report",
            "description": "LLM 생성 진단 보고서 전문 (OntologyValidator 검증 완료, 최대 2000자)"
          },
          "treatment_plan": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Treatment Plan",
            "description": "치료 계획 및 추적 관찰 권고"
          },
          "llm_model": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Llm Model",
            "description": "보고서 생성에 사용된 LLM 모델명"
          },
          "llm_iterations": {
            "type": "integer",
            "title": "Llm Iterations",
            "description": "Orchestrator 반복 횟수 (1 = 첫 시도 통과)"
          },
          "llm_latency_ms": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Llm Latency Ms",
            "description": "LLM 처리 시간 (밀리초)"
          },
          "ontology_passed": {
            "type": "boolean",
            "title": "Ontology Passed",
            "description": "OntologyValidator MEDICAL 도메인 검증 통과 여부"
          },
          "confidence_score": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
